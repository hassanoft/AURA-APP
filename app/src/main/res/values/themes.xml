<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Thème principal AURA (dark) -->
    <style name="Theme.Aura" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#18B05A</item>
        <item name="colorPrimaryDark">#0F8040</item>
        <item name="colorAccent">#4FD18A</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSurface">#1E1E1E</item>
        <item name="colorOnSurface">#E8E8E8</item>
        <item name="colorError">#CF6679</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">#121212</item>
        <item name="android:windowBackground">#121212</item>
    </style>

    <!-- Thème Splash Screen -->
    <style name="Theme.Aura.Splash" parent="Theme.Aura">
        <item name="android:windowBackground">#121212</item>
        <item name="android:windowFullscreen">true</item>
    </style>

</resources>
